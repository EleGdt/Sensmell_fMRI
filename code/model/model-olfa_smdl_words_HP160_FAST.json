{
  "Name": "Olfa univariate subject-level GLM (with subject-level condition contrasts)",
  "BIDSModelVersion": "1.0.0",
  "Description": "Run-level GLM with 2 conditions (Olfa, NonOlfa) + motion nuisance regressors. Subject-level model computes (a) condition-wise effects (olfa, nonOlfa) and (b) condition contrasts (olfa vs nonOlfa).",
  "Input": {
    "task": ["olfaWords"],
    "space": ["IXI549Space"]
  },
  "Nodes": [
    {
      "Level": "Run",
      "Name": "run_level",
      "GroupBy": ["subject", "run"],
      "Model": {
        "Type": "glm",
        "X": [
          "trial_type.olfaWords",
          "trial_type.nonOlfaWords",
          "trial_type.response",
          "trial_type.target",
          "trans_x",
          "trans_y",
          "trans_z",
          "rot_x",
          "rot_y",
          "rot_z"
        ],
        "HRF": {
          "Variables": ["trial_type.olfaWords", "trial_type.nonOlfaWords","trial_type.response","trial_type.target"],
          "Model": "spm"
        },
        "Software": {
          "SPM": {
            "SerialCorrelation": "FAST",
            "InclusiveMaskingThreshold": 0.8
          }
        },
        "Options": {
          "HighPassFilterCutoffHz": 0.00625
        }
      },
      "DummyContrasts": {
        "Test": "t",
        "Contrasts": ["trial_type.olfaWords", "trial_type.nonOlfaWords"]
      }
    },
    {
      "Level": "Subject",
      "Name": "subject_level",
      "GroupBy": ["subject", "contrast"],
      "Model": {
        "Type": "glm",
        "X": [1]
      },
      "Contrasts": [
        {
          "Name": "Olfa",
          "ConditionList": ["trial_type.olfaWords"],
          "Weights": [1],
          "Test": "t"
        },
        {
          "Name": "NonOlfa",
          "ConditionList": ["trial_type.nonOlfaWords"],
          "Weights": [1],
          "Test": "t"
        },
          {
          "Name": "Olfa_and_NonOlfa",
          "ConditionList": ["trial_type.olfaWords","trial_type.nonOlfaWords"],
          "Weights": [0.5, 0.5],
          "Test": "t"
        },

        {
          "Name": "Olfa_gt_NonOlfa",
          "ConditionList": ["trial_type.olfaWords", "trial_type.nonOlfaWords"],
          "Weights": [1, -1],
          "Test": "t"
        },
        {
          "Name": "NonOlfa_gt_Olfa",
          "ConditionList": ["trial_type.olfaWords", "trial_type.nonOlfaWords"],
          "Weights": [-1, 1],
          "Test": "t"
        }
      ]
    }
  ],
  "Edges": [
    {
      "Source": "run_level",
      "Destination": "subject_level"
    }
  ]
}
